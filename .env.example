# =============================================================================
# Frontend (Vite) – used in the React app. Prefix with VITE_
# =============================================================================
# Supabase project URL (local: http://127.0.0.1:54321 | hosted: from dashboard)
VITE_SUPABASE_URL=http://127.0.0.1:54321
# Anon/public key (safe to expose in the browser). Get from `supabase status` or dashboard
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# Backend / Edge Functions – never expose these in the frontend
# =============================================================================
# Same as VITE_SUPABASE_URL; used by Edge Functions when calling Supabase
SUPABASE_URL=http://127.0.0.1:54321
# Same as VITE_SUPABASE_ANON_KEY (optional for functions; they use service role)
SUPABASE_ANON_KEY=
# Service role key – full access, bypasses RLS. Get from `supabase status` or dashboard
SUPABASE_SERVICE_ROLE_KEY=
# Salt for anonymous fingerprint (IP + salt hashed). Generate: openssl rand -hex 32
FINGERPRINT_SALT=
